{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "files": {
    "ignore": [
      "**/.expo/**",
      "**/android/.gradle/**",
      "**/android/app/.cxx/**",
      "**/android/app/build/**",
      "**/android/app/google-services.json",
      "**/android/build/**",
      "**/dist/**",
      "**/src/generated/**",
      "**/node_modules/**"
    ]
  }
}
