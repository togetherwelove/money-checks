{
  "name": "mobile",
  "version": "0.1.0",
  "private": true,
  "main": "./index.ts",
  "scripts": {
    "build:info": "node scripts/write-build-info.cjs",
    "dev": "node scripts/write-build-info.cjs && expo start",
    "android": "node scripts/write-build-info.cjs && expo run:android",
    "ios": "node scripts/write-build-info.cjs && expo run:ios",
    "web": "node scripts/write-build-info.cjs && expo start --web --host lan",
    "web:build": "node scripts/write-build-info.cjs && expo export --platform web && workbox generateSW workbox-config.cjs",
    "web:serve": "python -m http.server 8080 --directory dist",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "~15.1.1",
    "@react-native-community/datetimepicker": "8.4.4",
    "@supabase/supabase-js": "^2.101.1",
    "expo": "~54.0.33",
    "expo-camera": "~17.0.10",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-sqlite": "^16.0.10",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-svg": "^15.12.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/react": "~19.1.17",
    "@vitest/coverage-v8": "^3.2.4",
    "babel-preset-expo": "~54.0.10",
    "typescript": "~5.9.3",
    "vitest": "^3.2.4",
    "workbox-cli": "^7.3.0"
  }
}
