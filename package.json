{
  "name": "money-checks",
  "private": true,
  "version": "1.0.2",
  "packageManager": "pnpm@10.16.1",
  "scripts": {
    "build:ios:dev": "pnpm verify:prebuild && npx eas-cli build -p ios --profile development",
    "build:ios:prod": "pnpm verify:prebuild && npx eas-cli build -p ios --profile production --auto-submit",
    "build:android:aab": "pnpm verify:prebuild && cd android && gradlew.bat bundleRelease",
    "dev": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "verify:doctor": "npx -y expo-doctor",
    "verify:prebuild": "pnpm verify:doctor && tsc --noEmit -p tsconfig.json",
    "db": "pnpm supabase db push --debug"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.11",
    "@expo/vector-icons": "~15.1.1",
    "@hcaptcha/react-native-hcaptcha": "^4.0.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-picker/picker": "2.11.4",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.11",
    "@supabase/supabase-js": "^2.101.1",
    "expo": "~55.0.24",
    "expo-apple-authentication": "~55.0.13",
    "expo-auth-session": "~55.0.16",
    "expo-clipboard": "~55.0.13",
    "expo-constants": "~55.0.16",
    "expo-crypto": "~55.0.15",
    "expo-dev-client": "~55.0.33",
    "expo-device": "~55.0.17",
    "expo-file-system": "~55.0.20",
    "expo-font": "~55.0.7",
    "expo-image-manipulator": "^55.0.16",
    "expo-image-picker": "~55.0.20",
    "expo-linear-gradient": "~55.0.14",
    "expo-localization": "~55.0.14",
    "expo-mail-composer": "~55.0.14",
    "expo-notifications": "~55.0.23",
    "expo-secure-store": "~55.0.14",
    "expo-sharing": "~55.0.19",
    "expo-sqlite": "~55.0.16",
    "expo-task-manager": "~55.0.16",
    "expo-tracking-transparency": "~55.0.14",
    "expo-updates": "~55.0.22",
    "i18next": "^26.0.8",
    "react": "19.2.0",
    "react-i18next": "^17.0.6",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.1",
    "react-native-google-mobile-ads": "^16.3.3",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-markdown-display": "^7.0.2",
    "react-native-modal": "14.0.0-rc.1",
    "react-native-pager-view": "8.0.0",
    "react-native-purchases": "^10.0.0",
    "react-native-reanimated": "~4.2.1",
    "react-native-root-siblings": "^5.0.1",
    "react-native-root-toast": "^4.0.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-webview": "^13.16.0",
    "react-native-worklets": "0.7.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/react": "~19.2.14",
    "@vitest/coverage-v8": "^3.2.4",
    "babel-preset-expo": "~55.0.19",
    "typescript": "~5.9.3",
    "vitest": "^3.2.4"
  }
}
