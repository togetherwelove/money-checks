{
  "name": "money-checks",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "build:info": "node scripts/write-build-info.cjs",
    "dev": "pnpm build:info && expo start",
    "android": "pnpm build:info && expo run:android",
    "ios": "pnpm build:info && expo run:ios",
    "web": "pnpm build:info && expo start --web",
    "web:build": "pnpm build:info && expo export --platform web && workbox generateSW workbox-config.cjs",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "verify": "pnpm exec tsc --noEmit -p tsconfig.json && pnpm test && pnpm lint && pnpm web:build",
    "supabase:link:dev": "node scripts/run-supabase-target.cjs development link",
    "supabase:link:test": "node scripts/run-supabase-target.cjs test link",
    "supabase:functions:deploy:dev": "node scripts/run-supabase-target.cjs development functions deploy delete-account",
    "supabase:functions:deploy:test": "node scripts/run-supabase-target.cjs test functions deploy delete-account",
    "bootstrap:mobile": "pnpm install",
    "dev:mobile:dev": "pnpm dev",
    "dev:mobile:test": "pnpm dev",
    "lint:mobile": "pnpm lint",
    "format:mobile": "pnpm format",
    "test:mobile": "pnpm test",
    "test:mobile:watch": "pnpm test:watch",
    "test:mobile:coverage": "pnpm test:coverage",
    "verify:mobile": "pnpm verify"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "~15.1.1",
    "@react-native-community/datetimepicker": "8.4.4",
    "@supabase/supabase-js": "^2.101.1",
    "expo": "~54.0.33",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-sqlite": "^16.0.10",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-collapsible": "^1.6.2",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "^2.31.1",
    "react-native-pager-view": "^8.0.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-root-siblings": "^5.0.1",
    "react-native-root-toast": "^4.0.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-svg": "^15.12.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "0.21.2",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/react": "~19.1.17",
    "@vitest/coverage-v8": "^3.2.4",
    "babel-preset-expo": "~54.0.10",
    "typescript": "~5.9.3",
    "vitest": "^3.2.4",
    "workbox-cli": "7.3.0"
  }
}
