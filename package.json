{
  "name": "money-checks",
  "private": true,
  "version": "1.0.7",
  "packageManager": "pnpm@10.16.1",
  "scripts": {
    "dev": "pnpm npx -y expo-doctor && pnpm typecheck && npx eas-cli build -p ios --profile development",
    "prod": "pnpm npx -y expo-doctor && pnpm typecheck && npx eas-cli build -p ios --profile production --auto-submit",
    "start": "expo start",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "fix": "npx expo install --fix",
    "check": "npx expo install --check",
    "push": "supabase db push"
  },
